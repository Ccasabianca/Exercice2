<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="utf-8" />
  <title>Ajouter un livre</title>
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>
  <h1>Ajouter un livre</h1>
  <p><a href="/books">← Retour</a></p>
  <form action="/books" method="POST">
    <p>Titre : <input type="text" name="title" required /></p>
    <p>Auteur : <input type="text" name="author" required /></p>
    <p>Prix : <input type="number" name="price" /></p>
    <p>Stock : <input type="number" name="stock" /></p>
    <p>Description : <input type="text" name="description" /></p>
    <p>Disponible : <input type="checkbox" name="available" checked /></p>
    <button type="submit">Submit</button>
  </form>
</body>

</html>